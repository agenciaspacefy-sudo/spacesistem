# SpaceSystem — variáveis de ambiente
# Copie este arquivo para `backend/.env` em desenvolvimento
# Em produção (Railway), defina essas variáveis no painel do serviço.

# ===== Obrigatórias =====
# Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=trocar_por_segredo_forte
SESSION_SECRET=trocar_por_outro_segredo_forte

# ===== Produção =====
# NODE_ENV=production ativa cookies secure (HTTPS) e CORS same-origin.
NODE_ENV=production

# Caminho do banco SQLite. Em produção aponte para um volume persistente
# montado no Railway (ex.: /data/spacefy.db).
DB_PATH=/data/spacefy.db

# URL pública do app (backend + frontend servidos juntos).
# No Railway, use o domínio gerado (ex.: https://seu-app.up.railway.app)
FRONTEND_URL=https://seu-app.up.railway.app
BACKEND_URL=https://seu-app.up.railway.app

# ===== Google OAuth (opcional) =====
# Callback autorizado no Google Console: ${BACKEND_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ===== Stripe (paywall + assinaturas) =====
# Pegue em: https://dashboard.stripe.com/apikeys (Secret key)
# Use sk_test_... para testes, sk_live_... para produção.
STRIPE_SECRET_KEY=

# Segredo do webhook. Gere ao criar um endpoint em:
# https://dashboard.stripe.com/webhooks → Add endpoint
# URL: ${BACKEND_URL}/webhook/stripe
# Eventos para escutar:
#   - checkout.session.completed
#   - customer.subscription.deleted
#   - invoke.payment_failed
# O Stripe mostra o "Signing secret" (whsec_...) — cole aqui.
STRIPE_WEBHOOK_SECRET=

# ===== Dev =====
# Em desenvolvimento local:
# NODE_ENV=development
# FRONTEND_URL=http://localhost:5173
# BACKEND_URL=http://localhost:3001
# PORT=3001
