# Copie este arquivo para `.env` e preencha com seus valores.

# Segredo usado para assinar JWTs. Gere com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=troque-por-uma-string-longa-e-aleatoria

# Segredo da sessão do Passport (OAuth). Gere o mesmo jeito.
SESSION_SECRET=outra-string-longa-e-aleatoria

# Credenciais Google OAuth — ver instruções em /backend/README-auth.md
GOOGLE_CLIENT_ID=seu-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=seu-client-secret

# URL pública do frontend (usada para redirecionar após OAuth)
FRONTEND_URL=http://localhost:5173

# URL pública do backend (usada no callback do Google)
BACKEND_URL=http://localhost:3001
